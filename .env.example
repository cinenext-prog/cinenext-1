# Local development env vars
# Copy this file to .env and fill with your own values.

# Required for loading video assets from Livepeer Studio API
VITE_LIVEPEER_API_KEY=

# Optional: preferred raw HLS prefix, e.g.
# https://vod-cdn.lp-playback.studio/raw/xxx/catalyst-vod-com/hls
VITE_LIVEPEER_RAW_HLS_PREFIX=

# Optional: TON NFT ownership check API key
VITE_TONCENTER_API_KEY=

# Optional: unlock target contract address
VITE_UNLOCK_CONTRACT=

# Postgres connection string (Neon / Supabase / Vercel Postgres)
DATABASE_URL=

# Optional server-side fallback prefix for playback URL generation
LIVEPEER_RAW_HLS_PREFIX=

# Set to true to disable ssl option for local non-ssl databases
DATABASE_SSL_DISABLE=false

# Telegram bot token used to verify Mini App initData
TELEGRAM_BOT_TOKEN=

# Optional initData max age in seconds (default 86400)
TELEGRAM_INIT_DATA_MAX_AGE=86400

# Admin token for write APIs, e.g. /api/dramas/upsert
ADMIN_WRITE_TOKEN=

# TON payee wallet (if empty, fallback to VITE_UNLOCK_CONTRACT)
TONPAY_MERCHANT_WALLET=

# Cron security for /api/cron/onchain-batch
CRON_SECRET=

# Chain label for onchain batch metadata
CHAIN_NAME=TON

# AdsGram rewarded ad block id
VITE_ADSGRAM_BLOCK_ID=

# Optional webhook to submit merkle root onchain automatically
ONCHAIN_ANCHOR_WEBHOOK=

# Optional bearer token for anchor webhook / callback
ONCHAIN_ANCHOR_TOKEN=
